class=\"summary-card\">\n          <div class=\"summary-value\">{{ stats.abnormalEnterpriseCount || 0 }}</div>\n          <div class=\"summary-label\">异常企业</div>\n        </div>\n      </div>\n\n      <div class=\"advice-grid\">\n        <el-card v-for=\"(item, index) in adviceList\" :key=\"index\" shadow=\"hover\" class=\"advice-item\">\n          <div class=\"tag\" :class=\"item.level\">{{ item.title }}</div>\n          <div class=\"content\">{{ item.content }}</div>\n          <div class=\"footer\">{{ item.actionLabel }}</div>\n        </el-card>\n      </div>\n    </el-card>\n  </div>\n</template>\n\n<script>\nexport default {\n  data() {\n    return {\n      adviceList: [],\n      stats: {}\n    }\n  },\n  created() {\n    this.fetchData()\n  },\n  methods: {\n    fetchData() {\n      this.$http.get('decision/dashboard').then(({ data }) => {\n        if (data && data.code === 0) {\n          this.adviceList = data.data.adviceList || []\n          this.stats = data.data.stats || {}\n        }\n      })\n    }\n  }\n}\n</script>\n\n<style scoped>\n.header-row { display: flex; justify-content: space-between; align-items: center; }\n.summary-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-bottom: 24px; }\n.summary-card { border: 1px solid #eef2ef; border-radius: 16px; padding: 20px; background: #fafcfb; }\n.summary-value { font-size: 30px; font-weight: 700; color: #1f3a2e; }\n.summary-label { margin-top: 8px; color: #64796e; }\n.advice-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 16px; }\n.advice-item { min-height: 180px; }\n.tag { display: inline-flex; padding: 4px 10px; border-radius: 999px; font-size: 12px; font-weight: 600; margin-bottom: 12px; }\n.tag.warning { background: #fff7e6; color: #d48806; }\n.tag.success { background: #e6f4ea; color: #389e0d; }\n.tag.danger { background: #fff1f0; color: #cf1322; }\n.tag.info { background: #e6f4ff; color: #1677ff; }\n.content { line-height: 1.8; color: #364a41; min-height: 72px; }\n.footer { margin-top: 12px; color: #2d5a27; font-size: 12px; font-weight: 600; }\n@media (max-width: 768px) {\n  .summary-row { grid-template-columns: 1fr; }\n}\n</style>\n"]}]}