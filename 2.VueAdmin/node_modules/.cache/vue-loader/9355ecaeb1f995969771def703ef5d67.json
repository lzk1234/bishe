=\"hero-header\">\n        <div>\n          <div class=\"hero-title\">经营决策中心</div>\n          <div class=\"hero-subtitle\">围绕销量预测、库存风险和补货建议形成经营闭环。</div>\n        </div>\n        <el-button type=\"primary\" plain @click=\"fetchData\">刷新数据</el-button>\n      </div>\n\n      <div class=\"summary-grid\">\n        <div class=\"summary-card\">\n          <div class=\"summary-label\">未来 7 天预测销量</div>\n          <div class=\"summary-value\">{{ formatCount(stats.forecast7DaysTotal) }}</div>\n          <div class=\"summary-desc\">\n            重点茶品：{{ forecastSummary.topProductName || '暂无预测' }}\n          </div>\n        </div>\n        <div class=\"summary-card warning\">\n          <div class=\"summary-label\">高风险库存数</div>\n          <div class=\"summary-value\">{{ formatCount(stats.highRiskProductCount) }}</div>\n          <div class=\"summary-desc\">风险等级为 warning 或 urgent 的茶品数量</div>\n        </div>\n        <div class=\"summary-card success\">\n          <div class=\"summary-label\">待补货茶品数</div>\n          <div class=\"summary-value\">{{ formatCount(stats.restockPendingCount) }}</div>\n          <div class=\"summary-desc\">建议补货量大于 0 的茶品数量</div>\n        </div>\n      </div>\n    </el-card>\n\n    <el-card shadow=\"never\" class=\"section-card\">\n      <div slot=\"header\" class=\"section-header\">\n        <span>销量预测服务</span>\n        <span class=\"section-tip\">按近 7 天订单数据进行加权移动平均预测</span>\n      </div>\n      <el-table :data=\"forecastList\" stripe>\n        <el-table-column prop=\"productName\" label=\"茶品名称\" min-width=\"180\" />\n        <el-table-column prop=\"category\" label=\"分类\" min-width=\"120\" />\n        <el-table-column prop=\"recentSales\" label=\"近 7 天销量\" width=\"120\" />\n        <el-table-column label=\"日均销量\" width=\"120\">\n          <template slot-scope=\"scope\">\n            {{ formatDecimal(scope.row.dailyAverage) }}\n          </template>\n        </el-table-column>\n        <el-table-column prop=\"forecast3Days\" label=\"预测 3 天销量\" width=\"120\" />\n        <el-table-column prop=\"forecast7Days\" label=\"预测 7 天销量\" width=\"120\" />\n        <el-table-column label=\"趋势\" width=\"100\">\n          <template slot-scope=\"scope\">\n            <el-tag size=\"mini\" :type=\"trendTagType(scope.row.trend)\">\n              {{ trendLabel(scope.row.trend) }}\n            </el-tag>\n          </template>\n        </el-table-column>\n      </el-table>\n    </el-card>\n\n    <el-card shadow=\"never\" class=\"section-card\">\n      <div slot=\"header\" class=\"section-header\">\n        <span>库存预警服务</span>\n        <span class=\"section-tip\">结合库存、预警值和销量消耗速度评估库存风险</span>\n      </div>\n      <el-table :data=\"inventoryRiskList\" stripe>\n        <el-table-column prop=\"productName\" label=\"茶品名称\" min-width=\"180\" />\n        <el-table-column prop=\"category\" label=\"分类\" min-width=\"120\" />\n        <el-table-column label=\"当前库存\" width=\"120\">\n          <template slot-scope=\"scope\">\n            {{ formatDecimal(scope.row.currentStock) }}\n          </template>\n        </el-table-column>\n        <el-table-column label=\"预警库存\" width=\"120\">\n          <template slot-scope=\"scope\">\n            {{ formatDecimal(scope.row.warningStock) }}\n          </template>\n        </el-table-column>\n        <el-table-column label=\"可售天数\" width=\"120\">\n          <template slot-scope=\"scope\">\n            {{ formatDecimal(scope.row.availableDays) }}\n          </template>\n        </el-table-column>\n        <el-table-column label=\"风险等级\" width=\"120\">\n          <template slot-scope=\"scope\">\n            <el-tag size=\"mini\" :type=\"riskTagType(scope.row.riskLevel)\">\n              {{ scope.row.riskLevel }}\n            </el-tag>\n          </template>\n        </el-table-column>\n        <el-table-column label=\"风险分值\" width=\"120\">\n          <template slot-scope=\"scope\">\n            {{ formatDecimal(scope.row.riskScore) }}\n          </template>\n        </el-table-column>\n        <el-table-column prop=\"warningReason\" label=\"预警原因\" min-width=\"260\" show-overflow-tooltip />\n      </el-table>\n    </el-card>\n\n    <el-card shadow=\"never\" class=\"section-card\">\n      <div slot=\"header\" class=\"section-header\">\n        <span>补货建议服务</span>\n        <span class=\"section-tip\">基于预测销量和库存风险自动给出补货优先级与建议量</span>\n      </div>\n      <el-table :data=\"restockPlanList\" stripe>\n        <el-table-column prop=\"productName\" label=\"茶品名称\" min-width=\"180\" />\n        <el-table-column prop=\"category\" label=\"分类\" min-width=\"120\" />\n        <el-table-column label=\"当前库存\" width=\"120\">\n          <template slot-scope=\"scope\">\n            {{ formatDecimal(scope.row.currentStock) }}\n          </template>\n        </el-table-column>\n        <el-table-column label=\"安全库存\" width=\"120\">\n          <template slot-scope=\"scope\">\n            {{ formatDecimal(scope.row.safetyStock) }}\n          </template>\n        </el-table-column>\n        <el-table-column prop=\"forecast7Days\" label=\"预测 7 天销量\" width=\"130\" />\n        <el-table-column label=\"建议补货量\" width=\"120\">\n          <template slot-scope=\"scope\">\n            {{ formatDecimal(scope.row.suggestedRestock) }}\n          </template>\n        </el-table-column>\n        <el-table-column prop=\"suggestedDays\" label=\"建议补货天数\" width=\"130\" />\n        <el-table-column label=\"优先级\" width=\"100\">\n          <template slot-scope=\"scope\">\n            <el-tag size=\"mini\" :type=\"priorityTagType(scope.row.priority)\">\n              {{ scope.row.priority }}\n            </el-tag>\n          </template>\n        </el-table-column>\n        <el-table-column prop=\"reason\" label=\"补货原因\" min-width=\"280\" show-overflow-tooltip />\n      </el-table>\n    </el-card>\n\n    <el-card shadow=\"never\" class=\"section-card\">\n      <div slot=\"header\" class=\"section-header\">\n        <span>经营建议</span>\n        <span class=\"section-tip\">结合核心指标生成的经营提示</span>\n      </div>\n      <div class=\"advice-grid\">\n        <el-card v-for=\"(item, index) in adviceList\" :key=\"index\" shadow=\"hover\" class=\"advice-item\">\n          <div class=\"advice-tag\" :class=\"item.level\">{{ item.title }}</div>\n          <div class=\"advice-content\">{{ item.content }}</div>\n          <div class=\"advice-action\">{{ item.actionLabel }}</div>\n        </el-card>\n      </div>\n    </el-card>\n  </div>\n</template>\n\n<script>\nexport default {\n  data() {\n    return {\n      stats: {},\n      forecastSummary: {},\n      forecastList: [],\n      inventoryRiskList: [],\n      restockPlanList: [],\n      adviceList: []\n    }\n  },\n  created() {\n    this.fetchData()\n  },\n  methods: {\n    fetchData() {\n      this.$http.get('decision/dashboard').then(({ data }) => {\n        if (data && data.code === 0) {\n          const payload = data.data || {}\n          this.stats = payload.stats || {}\n          this.forecastSummary = payload.forecastSummary || {}\n          this.forecastList = payload.forecastList || []\n          this.inventoryRiskList = payload.inventoryRiskList || []\n          this.restockPlanList = payload.restockPlanList || []\n          this.adviceList = payload.adviceList || []\n        }\n      })\n    },\n    formatCount(value) {\n      return Number(value || 0)\n    },\n    formatDecimal(value) {\n      const numeric = Number(value || 0)\n      return numeric % 1 === 0 ? numeric : numeric.toFixed(2)\n    },\n    trendLabel(trend) {\n      if (trend === 'up') {\n        return '上升'\n      }\n      if (trend === 'down') {\n        return '下降'\n      }\n      return '平稳'\n    },\n    trendTagType(trend) {\n      if (trend === 'up') {\n        return 'success'\n      }\n      if (trend === 'down') {\n        return 'danger'\n      }\n      return 'info'\n    },\n    riskTagType(level) {\n      if (level === 'urgent') {\n        return 'danger'\n      }\n      if (level === 'warning') {\n        return 'warning'\n      }\n      if (level === 'attention') {\n        return ''\n      }\n      return 'success'\n    },\n    priorityTagType(priority) {\n      if (priority === 'urgent') {\n        return 'danger'\n      }\n      if (priority === 'high') {\n        return 'warning'\n      }\n      if (priority === 'medium') {\n        return ''\n      }\n      if (priority === 'low') {\n        return 'success'\n      }\n      return 'info'\n    }\n  }\n}\n</script>\n\n<style scoped>\n.decision-page {\n  display: grid;\n  gap: 20px;\n}\n\n.hero-card {\n  border-radius: 18px;\n}\n\n.hero-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  margin-bottom: 20px;\n}\n\n.hero-title {\n  font-size: 24px;\n  font-weight: 700;\n  color: #1f3a2e;\n}\n\n.hero-subtitle {\n  margin-top: 8px;\n  color: #5f7569;\n}\n\n.summary-grid {\n  display: grid;\n  grid-template-columns: repeat(3, 1fr);\n  gap: 16px;\n}\n\n.summary-card {\n  padding: 20px;\n  border-radius: 16px;\n  background: linear-gradient(135deg, #f3faf5, #edf7ef);\n  border: 1px solid #e4efe7;\n}\n\n.summary-card.warning {\n  background: linear-gradient(135deg, #fff9ef, #fff3dd);\n  border-color: #fde3a7;\n}\n\n.summary-card.success {\n  background: linear-gradient(135deg, #eef9ff, #e4f5ff);\n  border-color: #cfe9ff;\n}\n\n.summary-label {\n  color: #60766a;\n  font-size: 13px;\n}\n\n.summary-value {\n  margin-top: 10px;\n  font-size: 34px;\n  font-weight: 700;\n  color: #1f3a2e;\n}\n\n.summary-desc {\n  margin-top: 10px;\n  color: #6b7f75;\n  font-size: 12px;\n}\n\n.section-card {\n  border-radius: 18px;\n}\n\n.section-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n}\n\n.section-tip {\n  font-size: 12px;\n  color: #7b8f84;\n}\n\n.advice-grid {\n  display: grid;\n  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));\n  gap: 16px;\n}\n\n.advice-item {\n  min-height: 170px;\n  border-radius: 16px;\n}\n\n.advice-tag {\n  display: inline-flex;\n  padding: 4px 10px;\n  border-radius: 999px;\n  font-size: 12px;\n  font-weight: 600;\n  margin-bottom: 12px;\n}\n\n.advice-tag.warning {\n  background: #fff7e6;\n  color: #d48806;\n}\n\n.advice-tag.success {\n  background: #e6f4ea;\n  color: #389e0d;\n}\n\n.advice-tag.danger {\n  background: #fff1f0;\n  color: #cf1322;\n}\n\n.advice-tag.info {\n  background: #e6f4ff;\n  color: #1677ff;\n}\n\n.advice-content {\n  min-height: 72px;\n  line-height: 1.8;\n  color: #31453c;\n}\n\n.advice-action {\n  margin-top: 12px;\n  color: #2d5a27;\n  font-size: 12px;\n  font-weight: 600;\n}\n\n@media (max-width: 1200px) {\n  .summary-grid {\n    grid-template-columns: 1fr;\n  }\n}\n\n@media (max-width: 768px) {\n  .hero-header,\n  .section-header {\n    flex-direction: column;\n    align-items: flex-start;\n    gap: 10px;\n  }\n}\n</style>\n"]}]}