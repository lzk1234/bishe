{"remainingRequest":"F:\\Desktop\\chaye\\TeaMallSystem\\2.VueAdmin\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!F:\\Desktop\\chaye\\TeaMallSystem\\2.VueAdmin\\src\\views\\home.vue?vue&type=style&index=0&id=358f7eb9&prod&lang=scss&scoped=true","dependencies":[{"path":"F:\\Desktop\\chaye\\TeaMallSystem\\2.VueAdmin\\src\\views\\home.vue","mtime":1776504217747},{"path":"F:\\Desktop\\chaye\\TeaMallSystem\\2.VueAdmin\\node_modules\\css-loader\\dist\\cjs.js","mtime":1776500966771},{"path":"F:\\Desktop\\chaye\\TeaMallSystem\\2.VueAdmin\\node_modules\\vue-loader\\lib\\loaders\\stylePostLoader.js","mtime":1776500969189},{"path":"F:\\Desktop\\chaye\\TeaMallSystem\\2.VueAdmin\\node_modules\\postcss-loader\\src\\index.js","mtime":1776500967584},{"path":"F:\\Desktop\\chaye\\TeaMallSystem\\2.VueAdmin\\node_modules\\sass-loader\\dist\\cjs.js","mtime":1776500966091},{"path":"F:\\Desktop\\chaye\\TeaMallSystem\\2.VueAdmin\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1776500966090},{"path":"F:\\Desktop\\chaye\\TeaMallSystem\\2.VueAdmin\\node_modules\\vue-loader\\lib\\index.js","mtime":1776500968436}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["home.vue"],"names":[],"mappings":";AAqLA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;;AAEA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA","file":"home.vue","sourceRoot":"src/views","sourcesContent":["<template>\r\n<div class=\"dashboard-container\">\r\n  <div class=\"welcome-section\">\r\n    <div class=\"welcome-text\">\r\n      <h1>欢迎回来, {{adminName}}</h1>\r\n      <p>这是您的茶叶商城系统管理概览</p>\r\n    </div>\r\n    <div class=\"date-display\">{{currentDate}}</div>\r\n  </div>\r\n\r\n  <el-row :gutter=\"24\" class=\"stat-cards\">\r\n    <el-col :xs=\"24\" :sm=\"12\" :lg=\"6\" v-for=\"(item, index) in stats\" :key=\"index\">\r\n      <el-card shadow=\"hover\" :body-style=\"{ padding: '0px' }\" class=\"stat-card\">\r\n        <div class=\"card-content\">\r\n          <div class=\"card-icon\" :style=\"{ backgroundColor: item.bg }\">\r\n            <i :class=\"item.icon\"></i>\r\n          </div>\r\n          <div class=\"card-info\">\r\n            <div class=\"card-value\">{{item.value}}</div>\r\n            <div class=\"card-label\">{{item.label}}</div>\r\n          </div>\r\n          <div class=\"card-trend\" :class=\"item.trend > 0 ? 'up' : 'down'\">\r\n            <i :class=\"item.trend > 0 ? 'el-icon-top' : 'el-icon-bottom'\"></i>\r\n            {{Math.abs(item.trend)}}%\r\n          </div>\r\n        </div>\r\n      </el-card>\r\n    </el-col>\r\n  </el-row>\r\n\r\n  <el-row :gutter=\"24\" class=\"main-charts\">\r\n    <el-col :span=\"16\">\r\n      <el-card class=\"chart-card\" header=\"销售额趋势 (近7天)\">\r\n        <div ref=\"salesChart\" style=\"height: 220px;\"></div>\r\n      </el-card>\r\n    </el-col>\r\n    <el-col :span=\"8\">\r\n      <el-card class=\"chart-card\" header=\"热门茶叶分类\">\r\n        <div ref=\"pieChart\" style=\"height: 220px;\"></div>\r\n      </el-card>\r\n    </el-col>\r\n  </el-row>\r\n\r\n  <el-row :gutter=\"24\" class=\"bottom-sections\">\r\n    <el-col :span=\"12\">\r\n      <el-card class=\"list-card\" header=\"最新订单\">\r\n        <el-table :data=\"recentOrders\" style=\"width: 100%\" max-height=\"450\">\r\n          <el-table-column prop=\"id\" label=\"订单号\" width=\"100\"></el-table-column>\r\n          <el-table-column prop=\"user\" label=\"用户\"></el-table-column>\r\n          <el-table-column prop=\"product\" label=\"茶叶名称\"></el-table-column>\r\n          <el-table-column prop=\"amount\" label=\"金额\">\r\n            <template slot-scope=\"scope\">\r\n              <span class=\"price\">¥{{scope.row.amount}}</span>\r\n            </template>\r\n          </el-table-column>\r\n          <el-table-column prop=\"status\" label=\"状态\">\r\n            <template slot-scope=\"scope\">\r\n              <el-tag :type=\"scope.row.statusType\">{{scope.row.status}}</el-tag>\r\n            </template>\r\n          </el-table-column>\r\n        </el-table>\r\n      </el-card>\r\n    </el-col>\r\n    <el-col :span=\"12\">\r\n      <el-card class=\"list-card\" header=\"库存预警\">\r\n      <div class=\"stock-list\">\r\n        <div v-for=\"item in lowStock\" :key=\"item.name\" class=\"stock-item\">\r\n          <div class=\"stock-info\">\r\n            <span class=\"stock-name\">{{item.name}}</span>\r\n            <span class=\"stock-count\">剩余: {{item.count}}</span>\r\n          </div>\r\n          <el-progress :percentage=\"item.percentage\" :format=\"() => ''\" :color=\"item.percentage < 20 ? '#f56c6c' : '#e6a23c'\"></el-progress>\r\n        </div>\r\n      </div>\r\n      </el-card>\r\n    </el-col>\r\n  </el-row>\r\n</div>\r\n</template>\r\n\r\n<script>\r\nimport * as echarts from 'echarts'\r\nexport default {\r\n  data() {\r\n    return {\r\n      adminName: '',\r\n      currentDate: '',\r\n      stats: [\r\n        { label: '总销售额', value: '¥12,840', icon: 'el-icon-money', bg: '#e8f5e9', trend: 12.5 },\r\n        { label: '今日订单', value: '42', icon: 'el-icon-shopping-cart-full', bg: '#fff3e0', trend: 8.2 },\r\n        { label: '新增用户', value: '15', icon: 'el-icon-user', bg: '#e3f2fd', trend: -2.4 },\r\n        { label: '待处理评论', value: '8', icon: 'el-icon-chat-line-round', bg: '#f3e5f5', trend: 5.1 }\r\n      ],\r\n      recentOrders: [\r\n        { id: '10234', user: '张三', product: '龙井特级', amount: '598.00', status: '待发货', statusType: 'warning' },\r\n        { id: '10233', user: '李四', product: '大红袍', amount: '1280.00', status: '已支付', statusType: 'success' },\r\n        { id: '10232', user: '王五', product: '普洱熟茶', amount: '345.00', status: '已完成', statusType: 'info' },\r\n        { id: '10231', user: '赵六', product: '碧螺春', amount: '880.00', status: '待发货', statusType: 'warning' },\r\n        { id: '10230', user: '孙七', product: '铁观音', amount: '456.00', status: '已支付', statusType: 'success' },\r\n        { id: '10229', user: '周八', product: '黄山毛峰', amount: '678.00', status: '已完成', statusType: 'info' },\r\n        { id: '10228', user: '吴九', product: '正山小种', amount: '920.00', status: '待发货', statusType: 'warning' },\r\n        { id: '10227', user: '郑十', product: '白毫银针', amount: '1580.00', status: '已支付', statusType: 'success' },\r\n        { id: '10226', user: '钱一', product: '君山银针', amount: '720.00', status: '已完成', statusType: 'info' },\r\n        { id: '10225', user: '冯二', product: '六安瓜片', amount: '490.00', status: '待发货', statusType: 'warning' }\r\n      ],\r\n      lowStock: [\r\n        { name: '西湖龙井', count: 5, percentage: 10 },\r\n        { name: '碧螺春', count: 12, percentage: 24 },\r\n        { name: '铁观音', count: 8, percentage: 16 },\r\n        { name: '大红袍', count: 3, percentage: 6 },\r\n        { name: '普洱生茶', count: 15, percentage: 30 },\r\n        { name: '黄山毛峰', count: 7, percentage: 14 },\r\n        { name: '正山小种', count: 9, percentage: 18 },\r\n        { name: '白毫银针', count: 4, percentage: 8 },\r\n        { name: '君山银针', count: 6, percentage: 12 },\r\n        { name: '六安瓜片', count: 10, percentage: 20 }\r\n      ]\r\n    };\r\n  },\r\n  mounted() {\r\n    this.adminName = this.$storage.get('adminName') || '管理员';\r\n    this.updateTime();\r\n    setInterval(this.updateTime, 1000);\r\n    this.initCharts();\r\n  },\r\n  methods: {\r\n    updateTime() {\r\n      const now = new Date();\r\n      this.currentDate = now.toLocaleDateString() + ' ' + now.toLocaleTimeString();\r\n    },\r\n    initCharts() {\r\n      const salesChart = echarts.init(this.$refs.salesChart);\r\n      salesChart.setOption({\r\n        tooltip: { trigger: 'axis' },\r\n        grid: { left: '3%', right: '4%', bottom: '3%', containLabel: true },\r\n        xAxis: { type: 'category', boundaryGap: false, data: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'] },\r\n        yAxis: { type: 'value' },\r\n        series: [{\r\n          name: '销售额',\r\n          type: 'line',\r\n          smooth: true,\r\n          data: [820, 932, 901, 934, 1290, 1330, 1320],\r\n          itemStyle: { color: '#2d5a27' },\r\n          areaStyle: {\r\n            color: new echarts.graphic.LinearGradient(0, 0, 0, 1, [\r\n              { offset: 0, color: 'rgba(45, 90, 39, 0.3)' },\r\n              { offset: 1, color: 'rgba(45, 90, 39, 0)' }\r\n            ])\r\n          }\r\n        }]\r\n      });\r\n\r\n      const pieChart = echarts.init(this.$refs.pieChart);\r\n      pieChart.setOption({\r\n        tooltip: { trigger: 'item' },\r\n        legend: { bottom: '5%', left: 'center' },\r\n        series: [{\r\n          type: 'pie',\r\n          radius: ['40%', '70%'],\r\n          avoidLabelOverlap: false,\r\n          itemStyle: { borderRadius: 10, borderColor: '#fff', borderWidth: 2 },\r\n          label: { show: false },\r\n          data: [\r\n            { value: 1048, name: '绿茶', itemStyle: { color: '#2d5a27' } },\r\n            { value: 735, name: '红茶', itemStyle: { color: '#e67e22' } },\r\n            { value: 580, name: '乌龙茶', itemStyle: { color: '#a04000' } },\r\n            { value: 484, name: '普洱茶', itemStyle: { color: '#641e16' } }\r\n          ]\r\n        }]\r\n      });\r\n\r\n      window.addEventListener('resize', () => {\r\n        salesChart.resize();\r\n        pieChart.resize();\r\n      });\r\n    }\r\n  }\r\n};\r\n</script>\r\n\r\n<style lang=\"scss\" scoped>\r\n.dashboard-container {\r\n  .welcome-section {\r\n    display: flex;\r\n    justify-content: space-between;\r\n    align-items: center;\r\n    margin-bottom: 15px;\r\n    \r\n    .welcome-text {\r\n      h1 {\r\n        margin: 0;\r\n        font-size: 24px;\r\n        color: #2c3e50;\r\n      }\r\n      p {\r\n        margin: 5px 0 0;\r\n        color: #7f8c8d;\r\n        font-size: 14px;\r\n      }\r\n    }\r\n    .date-display {\r\n      background: #ffffff;\r\n      padding: 10px 20px;\r\n      border-radius: 8px;\r\n      box-shadow: 0 2px 12px rgba(0,0,0,0.05);\r\n      color: #2d5a27;\r\n      font-weight: 600;\r\n    }\r\n  }\r\n\r\n  .stat-cards {\r\n    margin-bottom: 20px;\r\n    \r\n    .stat-card {\r\n      border: none;\r\n      border-radius: 12px;\r\n      \r\n      .card-content {\r\n        padding: 15px;\r\n        display: flex;\r\n        align-items: center;\r\n        position: relative;\r\n        \r\n        .card-icon {\r\n          width: 48px;\r\n          height: 48px;\r\n          border-radius: 12px;\r\n          display: flex;\r\n          align-items: center;\r\n          justify-content: center;\r\n          margin-right: 15px;\r\n          \r\n          i {\r\n            font-size: 24px;\r\n            color: #2c3e50;\r\n          }\r\n        }\r\n        \r\n        .card-info {\r\n          .card-value {\r\n            font-size: 20px;\r\n            font-weight: 700;\r\n            color: #2c3e50;\r\n          }\r\n          .card-label {\r\n            font-size: 13px;\r\n            color: #7f8c8d;\r\n            margin-top: 4px;\r\n          }\r\n        }\r\n        \r\n        .card-trend {\r\n          position: absolute;\r\n          top: 20px;\r\n          right: 20px;\r\n          font-size: 12px;\r\n          font-weight: 600;\r\n          display: flex;\r\n          align-items: center;\r\n          \r\n          &.up { color: #27ae60; }\r\n          &.down { color: #e74c3c; }\r\n          \r\n          i { margin-right: 2px; }\r\n        }\r\n      }\r\n    }\r\n  }\r\n\r\n  .chart-card, .list-card {\r\n    border-radius: 12px;\r\n    border: none;\r\n    margin-bottom: 20px;\r\n    \r\n    ::v-deep .el-card__header {\r\n      border-bottom: 1px solid #f0f4f2;\r\n      font-weight: 600;\r\n      color: #2c3e50;\r\n    }\r\n  }\r\n\r\n  .price {\r\n    color: #e67e22;\r\n    font-weight: 600;\r\n  }\r\n\r\n  .stock-list {\r\n    max-height: 450px;\r\n    overflow-y: auto;\r\n\r\n    &::-webkit-scrollbar {\r\n      width: 6px;\r\n    }\r\n    &::-webkit-scrollbar-thumb {\r\n      background: #c0c4cc;\r\n      border-radius: 3px;\r\n    }\r\n    &::-webkit-scrollbar-track {\r\n      background: transparent;\r\n    }\r\n  }\r\n\r\n  .stock-item {\r\n    margin-bottom: 20px;\r\n    \r\n    &:last-child { margin-bottom: 0; }\r\n    \r\n    .stock-info {\r\n      display: flex;\r\n      justify-content: space-between;\r\n      margin-bottom: 8px;\r\n      font-size: 14px;\r\n      \r\n      .stock-name { color: #2c3e50; font-weight: 500; }\r\n      .stock-count { color: #7f8c8d; }\r\n    }\r\n  }\r\n}\r\n</style>\r\n"]}]}