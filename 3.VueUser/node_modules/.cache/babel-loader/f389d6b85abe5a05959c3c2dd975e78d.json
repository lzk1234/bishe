mendationToday(client, config) {\n  const limit = config.params && config.params.limit ? config.params.limit : 8\n  return client.get('recommendation/user/list', {\n    params: {\n      limit\n    }\n  }).then(function (response) {\n    const payload = Object.assign({}, response.data, {\n      data: Array.isArray(response.data.data) ? response.data.data.slice(0, limit) : []\n    })\n    return createVueResourceResponse(config.request, payload)\n  })\n}\n\nfunction requestWithMockClient(request) {\n  const client = getMockHttpClient()\n  const config = createClientConfig(request)\n  syncCommonHeaders(client, config.headers)\n\n  if (normalizePath(config.url) === 'recommendation/today') {\n    return handleRecommendationToday(client, Object.assign({}, config, {\n      request\n    }))\n  }\n\n  return client.request(config).then(function (response) {\n    return createVueResourceResponse(request, response.data)\n  })\n}\n\nexport function installUserMockInterceptor(http, options) {\n  const realBaseUrl = options && options.realBaseUrl ? options.realBaseUrl : ''\n\n  http.interceptors.push(function (request, next) {\n    const path = normalizePath(request.getUrl ? request.getUrl() : request.url)\n\n    if (!shouldMockPath(path)) {\n      if (realBaseUrl && !request.root && !/^(https?:)?\\/\\//.test(request.url || '')) {\n        request.root = realBaseUrl\n      }\n      return next()\n    }\n\n    return requestWithMockClient(request)\n  })\n}\n"],"mappings":"AAAA,SAASA,oBAAoB,QAAQ,uBAAuB;AAE5D,MAAMC,aAAa,GAAG,CACpB,UAAU,EACV,UAAU,EACV,OAAO,EACP,SAAS,EACT,uBAAuB,EACvB,aAAa,EACb,OAAO,EACP,sCAAsC,EACtC,SAAS,EACT,iBAAiB,EACjB,gBAAgB,EAChB,mBAAmB,EACnB,kBAAkB,EAClB,iBAAiB,EACjB,gBAAgB,EAChB,UAAU,EACV,cAAc,EACd,iBAAiB,EACjB,gBAAgB,EAChB,eAAe,CAChB;AAED,MAAMC,qBAAqB,GAAG;EAC5B,cAAc,EAAE;AAClB,CAAC;AAED,IAAIC,cAAc;AAElB,SAASC,iBAAiBA,CAAA,EAAG;EAC3B,IAAI,CAACD,cAAc,EAAE;IACnBA,cAAc,GAAGH,oBAAoB,CAAC;MACpCK,OAAO,EAAEC,MAAM,CAACC;IAClB,CAAC,CAAC;EACJ;EACA,OAAOJ,cAAc;AACvB;AAEA