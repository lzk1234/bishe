CA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA","file":"home.vue","sourceRoot":"src/pages/home","sourcesContent":["<template>\r\n<div class=\"home-preview\">\r\n\t<!-- Section: Today's Recommendation -->\r\n\t<section class=\"recommend-section fade-in-up\">\r\n\t\t<div class=\"section-header\">\r\n\t\t\t<div class=\"header-left\">\r\n\t\t\t\t<h2 class=\"section-title\">今日推荐</h2>\r\n\t\t\t\t<p class=\"section-subtitle\">为您精选的茶叶推荐</p>\r\n\t\t\t</div>\r\n\t\t\t<div class=\"header-right\">\r\n\t\t\t\t<el-button \r\n\t\t\t\t\ttype=\"primary\" \r\n\t\t\t\t\ticon=\"el-icon-refresh\" \r\n\t\t\t\t\tsize=\"small\" \r\n\t\t\t\t\t@click=\"refreshRecommendations\"\r\n\t\t\t\t\t:disabled=\"!Token\"\r\n\t\t\t\t>\r\n\t\t\t\t\t刷新推荐\r\n\t\t\t\t</el-button>\r\n\t\t\t\t<div class=\"more-link\" @click=\"moreBtn('shangpinxinxi')\">\r\n\t\t\t\t\t<span>探索更多</span>\r\n\t\t\t\t\t<i class=\"el-icon-right\"></i>\r\n\t\t\t\t</div>\r\n\t\t\t</div>\r\n\t\t</div>\r\n\t\t\r\n\t\t<div class=\"product-grid\" v-loading=\"loading\">\r\n\t\t\t<div \r\n\t\t\t\tv-for=\"(item,index) in shangpinxinxiRecommend\" \r\n\t\t\t\t:key=\"index\" \r\n\t\t\t\tclass=\"product-card\"\r\n\t\t\t\t@click=\"toDetail('shangpinxinxiDetail', item)\"\r\n\t\t\t>\r\n\t\t\t\t<div class=\"image-wrapper\">\r\n\t\t\t\t\t<img v-if=\"preHttp(item.tupian)\" :src=\"item.tupian.split(',')[0]\" alt=\"\" />\r\n\t\t\t\t\t<img v-else :src=\"baseUrl + (item.tupian?item.tupian.split(',')[0]:'')\" alt=\"\" />\r\n\t\t\t\t\t<div class=\"hover-overlay\">\r\n\t\t\t\t\t\t<el-button type=\"primary\" size=\"small\" circle icon=\"el-icon-view\"></el-button>\r\n\t\t\t\t\t</div>\r\n\t\t\t\t</div>\r\n\t\t\t\t<div class=\"product-info\">\r\n\t\t\t\t\t<span class=\"category\">{{item.shangpinfenlei}}</span>\r\n\t\t\t\t\t<h3 class=\"name\">{{item.shangpinmingcheng}}</h3>\r\n\t\t\t\t\t<p class=\"brand\">{{item.pinpai}}</p>\r\n\t\t\t\t</div>\r\n\t\t\t</div>\r\n\t\t</div>\r\n\t\t<div class=\"empty-state\" v-if=\"!loading && shangpinxinxiRecommend.length === 0\">\r\n\t\t\t<i class=\"el-icon-box\"></i>\r\n\t\t\t<p>暂无推荐数据</p>\r\n\t\t</div>\r\n\t</section>\r\n\r\n\t<div class=\"bottom-sections fade-in-up\" style=\"animation-delay: 0.4s\">\r\n\t\t<!-- Section: News -->\r\n\t\t<section class=\"news-section\">\r\n\t\t\t<div class=\"section-header\">\r\n\t\t\t\t<h2 class=\"section-title\">商城资讯</h2>\r\n\t\t\t\t<div class=\"small-more\" @click=\"moreBtn('news')\">更多 <i class=\"el-icon-arrow-right\"></i></div>\r\n\t\t\t</div>\r\n\t\t\t<div class=\"news-list\">\r\n\t\t\t\t<div \r\n\t\t\t\t\tv-for=\"(item, index) in newsList.slice(0, 4)\" \r\n\t\t\t\t\t:key=\"index\" \r\n\t\t\t\t\tclass=\"news-item\"\r\n\t\t\t\t\t@click=\"toDetail('newsDetail', item)\"\r\n\t\t\t\t>\r\n\t\t\t\t\t<div class=\"news-date\">\r\n\t\t\t\t\t\t<span class=\"day\">{{item.addtime.split(' ')[0].split('-')[2]}}</span>\r\n\t\t\t\t\t\t<span class=\"month\">{{item.addtime.split(' ')[0].split('-')[1]}}月</span>\r\n\t\t\t\t\t</div>\r\n\t\t\t\t\t<div class=\"news-content\">\r\n\t\t\t\t\t\t<h4 class=\"news-title\">{{item.title}}</h4>\r\n\t\t\t\t\t\t<p class=\"news-desc\">{{item.introduction}}</p>\r\n\t\t\t\t\t</div>\r\n\t\t\t\t</div>\r\n\t\t\t</div>\r\n\t\t</section>\r\n\r\n\t\t<!-- Section: About Us -->\r\n\t\t<section class=\"about-section\">\r\n\t\t\t<div class=\"section-header\">\r\n\t\t\t\t<h2 class=\"section-title\">关于我们</h2>\r\n\t\t\t</div>\r\n\t\t\t<div class=\"about-card\">\r\n\t\t\t\t<div class=\"about-images\">\r\n\t\t\t\t\t<img :src=\"baseUrl + aboutUsDetail.picture1\" class=\"img1\">\r\n\t\t\t\t\t<img :src=\"baseUrl + aboutUsDetail.picture2\" class=\"img2\">\r\n\t\t\t\t</div>\r\n\t\t\t\t<div class=\"about-text\">\r\n\t\t\t\t\t<h3>{{aboutUsDetail.title}}</h3>\r\n\t\t\t\t\t<p class=\"subtitle\">{{aboutUsDetail.subtitle}}</p>\r\n\t\t\t\t\t<div class=\"content-preview\" v-html=\"aboutUsDetail.content\"></div>\r\n\t\t\t\t</div>\r\n\t\t\t</div>\r\n\t\t</section>\r\n\t</div>\r\n</div>\r\n</template>\r\n\r\n<script>\r\n  export default {\r\n    //数据集合\r\n    data() {\r\n      return {\r\n        baseUrl: '',\r\n        aboutUsDetail: {},\r\n        newsList: [],\r\n        shangpinxinxiRecommend: [],\r\n        loading: false,\r\n        Token: localStorage.getItem('Token'),\r\n        username: localStorage.getItem('username'),\r\n        userId: null\r\n      }\r\n    },\r\n    created() {\r\n      this.baseUrl = this.$config.baseUrl;\r\n      this.getNewsList();\r\n      this.getAboutUs();\r\n      this.getList();\r\n    },\r\n    //方法集合\r\n    methods: {\r\n      preHttp(str) {\r\n          return str && str.substr(0,4)=='http';\r\n      },\r\n      getAboutUs() {\r\n          this.$http.get('aboutus/detail/1', {}).then(res => {\r\n            if(res.data.code == 0) {\r\n              this.aboutUsDetail = res.data.data;\r\n            }\r\n          })\r\n      },\r\n\t\tgetNewsList() {\r\n\t\t\tthis.$http.get('news/list', {params: {\r\n\t\t\t\tpage: 1,\r\n\t\t\t\tlimit: 6,\r\n\t\t\torder: 'desc'}}).then(res => {\r\n\t\t\t\tif (res.data.code == 0) {\r\n\t\t\t\t\tthis.newsList = res.data.data.list;\r\n\t\t\t\t\t\r\n\t\t\t\t\t\r\n\t\t\t\t}\r\n\t\t\t});\r\n\t\t},\r\n\t\tgetList() {\r\n      this.loading = true;\r\n      let url = 'recommendation/today?limit=8';\r\n      if (this.userId) {\r\n          url += `&userid=${this.userId}`;\r\n      }\r\n      \r\n      this.$http.get(url).then(res => {\r\n        if (res.data.code == 0) {\r\n          this.shangpinxinxiRecommend = res.data.data;\r\n        } else {\r\n          this.$message.error(res.data.msg);\r\n        }\r\n        this.loading = false;\r\n      }).catch(() => {\r\n        this.loading = false;\r\n      });\r\n    },\r\n    refreshRecommendations() {\r\n      if (!this.Token) {\r\n        this.$message.warning('请先登录');\r\n        return;\r\n      }\r\n      \r\n      this.loading = true;\r\n      // 先获取userId\r\n      this.$http.get('yonghu/session').then(res => {\r\n        if (res.data.code == 0 && res.data.data) {\r\n          const userId = res.data.data.id;\r\n          this.$http.post(`recommendation/refresh?userid=${userId}`).then(res2 => {\r\n            if (res2.data.code == 0) {\r\n              this.$message.success('刷新成功');\r\n              this.userId = userId;\r\n              this.getList();\r\n            } else {\r\n              this.$message.error(res2.data.msg);\r\n              this.loading = false;\r\n            }\r\n          }).catch(() => {\r\n            this.loading = false;\r\n          });\r\n        } else {\r\n          this.$message.error('获取用户信息失败');\r\n          this.loading = false;\r\n        }\r\n      }).catch(() => {\r\n        this.loading = false;\r\n      });\r\n    },\r\n\t\ttoDetail(path, item) {\r\n\t\t\tthis.$router.push({path: '/index/' + path, query: {detailObj: JSON.stringify(item)}});\r\n\t\t},\r\n\t\tmoreBtn(path) {\r\n\t\t\tthis.$router.push({path: '/index/' + path});\r\n\t\t}\r\n    }\r\n  }\r\n</script>\r\n\r\n<style rel=\"stylesheet/scss\" lang=\"scss\" scoped>\r\n\t.home-preview {\r\n\t\tmax-width: 1200px;\r\n\t\tmargin: 0 auto;\r\n\t\tpadding: 40px 0;\r\n\t}\r\n\r\n\t.section-header {\r\n\t\tdisplay: flex;\r\n\t\tjustify-content: space-between;\r\n\t\talign-items: center;\r\n\t\tmargin-bottom: 40px;\r\n\r\n\t\t.header-left {\r\n\t\t\tdisplay: flex;\r\n\t\t\tflex-direction: column;\r\n\t\t\talign-items: flex-start;\r\n\r\n\t\t\t.section-title {\r\n\t\t\t\tfont-size: 28px;\r\n\t\t\t\tcolor: var(--text-main);\r\n\t\t\t\tmargin: 0 0 10px;\r\n\t\t\t\tfont-wei