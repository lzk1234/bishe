        <el-button\n            type=\"primary\"\n            icon=\"el-icon-refresh\"\n            size=\"small\"\n            @click=\"refreshRecommendations\"\n            :disabled=\"!token\"\n          >\n            刷新推荐\n          </el-button>\n          <div class=\"more-link\" @click=\"moreBtn('recommendation')\">\n            <span>查看更多</span>\n            <i class=\"el-icon-right\"></i>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"product-grid\" v-loading=\"loading\">\n        <div\n          v-for=\"item in shangpinxinxiRecommend\"\n          :key=\"item.id || item.goodid\"\n          class=\"product-card\"\n          @click=\"toGoodsDetail(item)\"\n        >\n          <div class=\"image-wrapper\">\n            <img v-if=\"preHttp(item.tupian)\" :src=\"item.tupian.split(',')[0]\" alt=\"\" />\n            <img v-else :src=\"baseUrl + imagePath(item.tupian)\" alt=\"\" />\n            <div class=\"hover-overlay\">\n              <el-button type=\"primary\" size=\"small\" circle icon=\"el-icon-view\"></el-button>\n            </div>\n          </div>\n          <div class=\"product-info\">\n            <span class=\"category\">{{ item.shangpinfenlei || '未分类' }}</span>\n            <h3 class=\"name\">{{ item.shangpinmingcheng }}</h3>\n            <p class=\"brand\">{{ item.pinpai || '暂无品牌' }}</p>\n            <p class=\"brand\" v-if=\"item.reason\">{{ item.reason }}</p>\n          </div>\n        </div>\n      </div>\n      <div class=\"empty-state\" v-if=\"!loading && shangpinxinxiRecommend.length === 0\">\n        <i class=\"el-icon-box\"></i>\n        <p>暂无推荐数据</p>\n      </div>\n    </section>\n\n    <div class=\"bottom-sections fade-in-up\" style=\"animation-delay: 0.4s\">\n      <section class=\"news-section\">\n        <div class=\"section-header\">\n          <h2 class=\"section-title\">商城资讯</h2>\n          <div class=\"small-more\" @click=\"moreBtn('news')\">更多 <i class=\"el-icon-arrow-right\"></i></div>\n        </div>\n        <div class=\"news-list\">\n          <div\n            v-for=\"(item, index) in newsList.slice(0, 4)\"\n            :key=\"index\"\n            class=\"news-item\"\n            @click=\"toDetail('newsDetail', item)\"\n          >\n            <div class=\"news-date\">\n              <span class=\"day\">{{ getDay(item.addtime) }}</span>\n              <span class=\"month\">{{ getMonth(item.addtime) }}月</span>\n            </div>\n            <div class=\"news-content\">\n              <h4 class=\"news-title\">{{ item.title }}</h4>\n              <p class=\"news-desc\">{{ item.introduction }}</p>\n            </div>\n          </div>\n        </div>\n      </section>\n\n      <section class=\"about-section\">\n        <div class=\"section-header\">\n          <h2 class=\"section-title\">关于我们</h2>\n        </div>\n        <div class=\"about-card\">\n          <div class=\"about-images\">\n            <img :src=\"baseUrl + (aboutUsDetail.picture1 || '')\" class=\"img1\">\n            <img :src=\"baseUrl + (aboutUsDetail.picture2 || '')\" class=\"img2\">\n          </div>\n          <div class=\"about-text\">\n            <h3>{{ aboutUsDetail.title }}</h3>\n            <p class=\"subtitle\">{{ aboutUsDetail.subtitle }}</p>\n            <div class=\"content-preview\" v-html=\"aboutUsDetail.content\"></div>\n          </div>\n        </div>\n      </section>\n    </div>\n  </div>\n</template>\n\n<script>\nexport default {\n  data() {\n    return {\n      baseUrl: '',\n      aboutUsDetail: {},\n      newsList: [],\n      shangpinxinxiRecommend: [],\n      loading: false,\n      token: localStorage.getItem('Token')\n    }\n  },\n  created() {\n    this.baseUrl = this.$config.baseUrl\n    this.getNewsList()\n    this.getAboutUs()\n    this.getList()\n  },\n  methods: {\n    preHttp(str) {\n      return !!str && str.substr(0, 4) === 'http'\n    },\n    imagePath(value) {\n      return value ? value.split(',')[0] : ''\n    },\n    getDay(value) {\n      return value ? value.split(' ')[0].split('-')[2] : ''\n    },\n    getMonth(value) {\n      return value ? value.split(' ')[0].split('-')[1] : ''\n    },\n    getAboutUs() {\n      this.$http.get('aboutus/detail/1').then(res => {\n        if (res.data.code === 0) {\n          this.aboutUsDetail = res.data.data || {}\n        }\n      })\n    },\n    getNewsList() {\n      this.$http.get('news/list', {\n        params: {\n          page: 1,\n          limit: 6,\n          order: 'desc'\n        }\n      }).then(res => {\n        if (res.data.code === 0) {\n          this.newsList = (res.data.data && res.data.data.list) || []\n        }\n      })\n    },\n    getList() {\n      this.loading = true\n      this.$http.get('recommendation/today', {\n        params: {\n          limit: 8\n        }\n      }).then(res => {\n        if (res.data.code === 0) {\n          this.shangpinxinxiRecommend = res.data.data || []\n        } else {\n          this.$message.error(res.data.msg)\n        }\n        this.loading = false\n      }).catch(() => {\n        this.loading = false\n      })\n    },\n    refreshRecommendations() {\n      if (!this.token) {\n        this.$message.warning('请先登录')\n        return\n      }\n\n      this.loading = true\n      this.$http.post('recommendation/refresh').then(res => {\n        if (res.data.code === 0) {\n          this.$message.success('刷新成功')\n          this.getList()\n        } else {\n          this.$message.error(res.data.msg)\n          this.loading = false\n        }\n      }).catch(() => {\n        this.loading = false\n      })\n    },\n    toGoodsDetail(item) {\n      const detailObj = Object.assign({}, item, { id: item.goodid })\n      this.$router.push({\n        path: '/index/shangpinxinxiDetail',\n        query: {\n          detailObj: JSON.stringify(detailObj)\n        }\n      })\n    },\n    toDetail(path, item) {\n      this.$router.push({ path: `/index/${path}`, query: { detailObj: JSON.stringify(item) } })\n    },\n    moreBtn(path) {\n      this.$router.push({ path: `/index/${path}` })\n    }\n  }\n}\n</script>\n\n<style rel=\"stylesheet/scss\" lang=\"scss\" scoped>\n.home-preview {\n  max-width: 1200px;\n  margin: 0 auto;\n  padding: 40px 0;\n}\n\n.section-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  margin-bottom: 40px;\n}\n\n.header-left {\n  display: flex;\n  flex-direction: column;\n  align-items: flex-start;\n}\n\n.section-title {\n  font-size: 28px;\n  color: var(--text-main);\n  margin: 0 0 10px;\n  font-weight: 600;\n  letter-spacing: 1px;\n}\n\n.section-subtitle {\n  font-size: 14px;\n  color: var(--text-secondary);\n  margin: 0;\n}\n\n.header-right {\n  display: flex;\n  align-items: center;\n  gap: 15px;\n}\n\n.more-link {\n  cursor: pointer;\n  color: var(--primary-color);\n  font-size: 14px;\n  display: flex;\n  align-items: center;\n  gap: 5px;\n  transition: var(--transition-main);\n}\n\n.more-link:hover {\n  gap: 10px;\n  opacity: 0.8;\n}\n\n.product-grid {\n  display: grid;\n  grid-template-columns: repeat(4, 1fr);\n  gap: 25px;\n  margin-bottom: 60px;\n}\n\n.product-card {\n  background: #fff;\n  border-radius: var(--radius-main);\n  overflow: hidden;\n  box-shadow: var(--shadow-soft);\n  transition: var(--transition-main);\n  cursor: pointer;\n}\n\n.product-card:hover {\n  transform: translateY(-8px);\n  box-shadow: var(--shadow-hover);\n}\n\n.product-card:hover .hover-overlay {\n  opacity: 1;\n}\n\n.image-wrapper {\n  position: relative;\n  height: 240px;\n  overflow: hidden;\n}\n\n.image-wrapper img {\n  width: 100%;\n  height: 100%;\n  object-fit: cover;\n  transition: transform 0.5s ease;\n}\n\n.hover-overlay {\n  position: absolute;\n  top: 0;\n  left: 0;\n  width: 100%;\n  height: 100%;\n  background: rgba(0, 0, 0, 0.2);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  opacity: 0;\n  transition: var(--transition-main);\n}\n\n.product-info {\n  padding: 20px;\n}\n\n.category {\n  font-size: 12px;\n  color: var(--primary-color);\n  text-transform: uppercase;\n  letter-spacing: 1px;\n  margin-bottom: 8px;\n  display: block;\n}\n\n.name {\n  font-size: 16px;\n  color: var(--text-main);\n  margin: 0 0 5px;\n  font-weight: 500;\n  white-space: nowrap;\n  overflow: hidden;\n  text-overflow: ellipsis;\n}\n\n.brand {\n  font-size: 13px;\n  color: var(--text-secondary);\n  margin: 0 0 15px;\n}\n\n.bottom-sections {\n  display: flex;\n  gap: 40px;\n  margin-top: 40px;\n}\n\n.news-section,\n.about-section {\n  flex: 1;\n  background: #fff;\n  padding: 30px;\n  border-radius: var(--radius-main);\n  box-shadow: var(--shadow-soft);\n  height: fit-content;\n}\n\n.small-more {\n  cursor: pointer;\n  font-size: 13px;\n  color: var(--text-secondary);\n}\n\n.small-more:hover {\n  color: var(--primary-color);\n}\n\n.news-item {\n  display: flex;\n  gap: 20px;\n  padding: 15px 0;\n  border-bottom: 1px solid #f0f0f0;\n  cursor: pointer;\n  transition: var(--transition-main);\n}\n\n.news-item:last-child {\n  border-bottom: none;\n}\n\n.news-item:hover {\n  padding-left: 5px;\n}\n\n.news-item:hover .news-title {\n  color: var(--primary-color);\n}\n\n.news-date {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  justify-content: center;\n  min-width: 60px;\n  height: 60px;\n  background: #f8f9fa;\n  border-radius: 8px;\n}\n\n.day {\n  font-size: 20px;\n  font-weight: 600;\n  color: var(--text-main);\n}\n\n.month {\n  font-size: 12px;\n  color: var(--text-secondary);\n}\n\n.news-title {\n  font-size: 15px;\n  margin: 0 0 5px;\n  font-weight: 500;\n  color: var(--text-main);\n}\n\n.news-desc {\n  font-size: 13px;\n  color: var(--text-secondary);\n  margin: 0;\n  display: -webkit-box;\n  -webkit-line-clamp: 2;\n  -webkit-box-orient: vertical;\n  overflow: hidden;\n}\n\n.about-images {\n  display: flex;\n  gap: 15px;\n  margin-bottom: 20px;\n}\n\n.about-images img {\n  flex: 1;\n  height: 180px;\n  object-fit: cover;\n  border-radius: 8px;\n}\n\n.about-text h3 {\n  font-size: 18px;\n  margin: 0 0 5px;\n  color: var(--text-main);\n}\n\n.subtitle {\n  font-size: 14px;\n  color: var(--text-secondary);\n  margin: 0 0 15px;\n}\n\n.content-preview {\n  font-size: 14px;\n  color: var(--text-secondary);\n  line-height: 1.6;\n  height: 100px;\n  overflow: hidden;\n  display: -webkit-box;\n  -webkit-line-clamp: 4;\n  -webkit-box-orient: vertical;\n}\n\n.empty-state {\n  text-align: center;\n  padding: 60px 20px;\n  background: #fff;\n  border-radius: var(--radius-main);\n  box-shadow: var(--shadow-soft);\n}\n\n.empty-state i {\n  font-size: 64px;\n  color: #ddd;\n  margin-bottom: 20px;\n}\n\n.empty-state p {\n  font-size: 16px;\n  color: var(--text-secondary);\n  margin: 0;\n}\n</style>\n"]}]}